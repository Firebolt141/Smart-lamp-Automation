<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Static shortcut: Turn lamp ON
        Accessible by long-pressing the app icon on the home screen,
        or via Google Assistant ("Run Turn lamp on").
    -->
    <shortcut
        android:shortcutId="lamp_on"
        android:enabled="true"
        android:shortcutShortLabel="@string/shortcut_on_short_label"
        android:shortcutLongLabel="@string/shortcut_on_long_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.lampsmart.controller"
            android:targetClass="com.lampsmart.controller.TurnOnActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <!--
        Static shortcut: Turn lamp OFF
        Accessible by long-pressing the app icon on the home screen,
        or via Google Assistant ("Run Turn lamp off").
    -->
    <shortcut
        android:shortcutId="lamp_off"
        android:enabled="true"
        android:shortcutShortLabel="@string/shortcut_off_short_label"
        android:shortcutLongLabel="@string/shortcut_off_long_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.lampsmart.controller"
            android:targetClass="com.lampsmart.controller.TurnOffActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

</shortcuts>
